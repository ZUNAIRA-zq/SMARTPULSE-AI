# SmartPulse AI - Environment Variables Template
# Copy this file to '.env' and fill in your details. Never commit '.env' to git.

# 1. AI Configuration
# Google Gemini API Key — used by the Insight Generator Agent (gemini-1.5-flash).
# Obtain yours at https://aistudio.google.com/app/apikey
# If left as the placeholder value, the agent falls back to the built-in rule-based analyzer.
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Backend Server Settings
HOST=127.0.0.1
PORT=8000

# 3. Frontend Settings (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# 4. Email Alert Settings (Gmail MCP / SMTP Fallback)
# For actual Gmail sending, use your Gmail email and an App Password (not your primary password).
# If these are left as placeholders, the Alert Agent runs in Mock mode and logs emails to backend/db/alerts.json.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_RECIPIENT_EMAIL=recipient_email@gmail.com
